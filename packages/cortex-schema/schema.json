{
  "$schema":     "http://json-schema.org/draft-07/schema#",
  "$id":         "https://cortex.dev/schema/v1.json",
  "title":       "Cortex Profile Configuration",
  "description": "Schema for cortex.yml — the config file that drives the Cortex GitHub Action.",
  "type":        "object",
  "required":    ["identity"],
  "additionalProperties": false,

  "properties": {
    "version": {
      "type":        "integer",
      "const":       1,
      "default":     1,
      "description": "Cortex schema version. Currently always 1."
    },

    "identity": {
      "type": "object",
      "required": ["name", "github_user"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "description": "Display name shown in titles" },
        "github_user": { "type": "string", "minLength": 1, "maxLength": 39, "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38})$" },
        "tagline":     { "type": "string", "default": "" },
        "location":    { "type": "string", "default": "" },
        "pronouns":    { "type": "string", "default": "" },
        "email":       { "type": "string", "anyOf": [{ "maxLength": 0 }, { "format": "email" }] },
        "socials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "linkedin":  { "type": "string" },
            "telegram":  { "type": "string" },
            "instagram": { "type": "string" },
            "twitter":   { "type": "string" }
          }
        }
      }
    },

    "brand": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "palette": {
          "type":        "string",
          "enum":        ["neon-rainbow", "monochrome", "cyberpunk", "minimal", "retro"],
          "default":     "neon-rainbow",
          "description": "Named palette preset"
        },
        "colors": {
          "type": "object",
          "additionalProperties": false,
          "description": "Override individual colors (takes precedence over palette)",
          "properties": {
            "primary":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "secondary":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent_a":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent_b":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent_c":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent_d":   { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "background": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          }
        },
        "typography": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "display": { "type": "string", "default": "Inter",          "description": "Display font (any Google Font name)" },
            "mono":    { "type": "string", "default": "JetBrains Mono", "description": "Monospace font" },
            "scale":   { "type": "number", "minimum": 0.5, "maximum": 1.5, "default": 1.0, "description": "Global font-size multiplier (0.85 compact, 1.15 comfortable)" }
          }
        },
        "animations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":   { "type": "boolean", "default": true },
            "intensity": { "type": "string",  "enum": ["off", "subtle", "medium", "high"], "default": "high" },
            "speed":     { "type": "number",  "minimum": 0.25, "maximum": 4.0, "default": 1.0, "description": "Animation duration multiplier (>1 slower, <1 faster). Use 2.0+ for reduced-motion preferences." }
          }
        }
      }
    },

    "brain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "source":  { "type": "string", "enum": ["wikimedia", "abstract", "custom"], "default": "wikimedia" },
        "regions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "frontal":    { "$ref": "#/definitions/brainRegion" },
            "parietal":   { "$ref": "#/definitions/brainRegion" },
            "occipital":  { "$ref": "#/definitions/brainRegion" },
            "temporal":   { "$ref": "#/definitions/brainRegion" },
            "cerebellum": { "$ref": "#/definitions/brainRegion" },
            "brainstem":  { "$ref": "#/definitions/brainRegion" }
          }
        },
        "three_d": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":       { "type": "boolean", "default": true },
            "auto_rotate":   { "type": "boolean", "default": true },
            "custom_domain": { "type": "string", "description": "Pro tier — your custom domain" }
          }
        },
        "heatmap": {
          "type": "object",
          "additionalProperties": false,
          "description": "Pro tier — lobes glow brighter where you actually contribute",
          "properties": {
            "enabled": { "type": "boolean", "default": false }
          }
        },
        "atmosphere": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional ambient-effect toggles. Turn off for a cleaner brain or to honor reduced-motion preferences.",
          "properties": {
            "show_particles": { "type": "boolean", "default": true, "description": "16 ambient drifting particles behind the brain" },
            "show_aura":      { "type": "boolean", "default": true, "description": "Pink/purple radial glow centered on the canvas" },
            "show_halos":     { "type": "boolean", "default": true, "description": "Static rings at leader-line endpoints" },
            "wobble":         { "type": "boolean", "default": true, "description": "3D scaleX/skewY breathing animation on brain anatomy" }
          }
        }
      }
    },

    "typing":        { "$ref": "#/definitions/typing" },
    "cards":         { "$ref": "#/definitions/cards" },
    "auto_update":   { "$ref": "#/definitions/autoUpdate" },
    "contributions": { "$ref": "#/definitions/contributions" },
    "pro":           { "$ref": "#/definitions/proFeatures" }
  },

  "definitions": {
    "brainRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain"],
      "properties": {
        "domain":  { "type": "string", "description": "Skill domain shown on the label" },
        "tools":   { "type": "array", "items": { "type": "string" }, "default": [] },
        "emoji":   { "type": "string", "default": "", "description": "Optional emoji for the region's tech card" },
        "caption": { "type": "string", "default": "", "description": "Optional short caption shown under the title" },
        "tagline": { "type": "string", "default": "", "description": "Optional tagline shown on the card" },
        "mastery": { "type": "string", "enum": ["EXPERT", "ADVANCED", "PROFICIENT", "GROWING"], "description": "Self-assessed proficiency level" },
        "stats":   { "type": "array", "items": { "$ref": "#/definitions/statEntry" }, "maxItems": 3, "default": [] }
      }
    },

    "statEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["num", "label"],
      "properties": {
        "num":   { "type": "string", "description": "Display value (e.g. '15+', '52★', 'FIRST')" },
        "label": { "type": "string", "description": "Caption under the value" }
      }
    },

    "yearEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year"],
      "properties": {
        "year":     { "type": "integer", "minimum": 2008, "maximum": 2100 },
        "label":    { "type": "string", "default": "", "description": "Era badge (e.g. 'ORIGIN', 'GROWTH', 'CURRENT YEAR')" },
        "headline": { "type": "string", "default": "", "description": "Short title for the year" },
        "bullets":  { "type": "array", "items": { "type": "string" }, "maxItems": 8, "default": [] },
        "stats":    { "type": "array", "items": { "$ref": "#/definitions/statEntry" }, "maxItems": 3, "default": [] }
      }
    },

    "typing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "header": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":            { "type": "boolean", "default": true },
            "languages":          { "type": "array", "items": { "type": "string", "enum": ["en", "de", "ar", "es", "fr", "ja", "zh", "ru", "tr", "pt"] }, "default": ["en"] },
            "lines_per_language": { "type": "integer", "minimum": 1, "maximum": 30, "default": 10 },
            "cycle":              { "type": "string", "enum": ["fast", "medium", "slow"], "default": "medium" }
          }
        },
        "about": { "$ref": "#/definitions/typingBody" },
        "motto": { "$ref": "#/definitions/typingBody" }
      }
    },

    "typingBody": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "lines":   { "type": "integer", "minimum": 3, "maximum": 100, "default": 30 },
        "include": { "type": "array",   "items": { "type": "string", "enum": ["personal", "generic"] }, "default": ["personal", "generic"] }
      }
    },

    "cards": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tech_stack": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":    { "type": "boolean", "default": true },
            "show_stats": { "type": "boolean", "default": true },
            "categories": { "type": "array", "items": { "type": "string" } }
          }
        },
        "current_focus": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "tiles":   { "type": "array", "items": { "$ref": "#/definitions/focusTile" }, "default": [] }
          }
        },
        "yearly_highlights": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":          { "type": "boolean", "default": true },
            "start_year":       { "type": "integer", "minimum": 2008, "default": 2023 },
            "bullets_per_year": { "type": "integer", "minimum": 1, "maximum": 8, "default": 3 },
            "years":            { "type": "array", "items": { "$ref": "#/definitions/yearEntry" }, "maxItems": 6, "default": [] }
          }
        },
        "header": { "$ref": "#/definitions/banner" },
        "footer": { "$ref": "#/definitions/banner" },
        "badges": { "$ref": "#/definitions/badges" },
        "galaxy": { "$ref": "#/definitions/galaxy" },
        "synthwave": { "$ref": "#/definitions/synthwave" },
        "radar": { "$ref": "#/definitions/radar" },
        "roadmap": { "$ref": "#/definitions/roadmap" },
        "heatmap": { "$ref": "#/definitions/heatmap" },
        "cubes": { "$ref": "#/definitions/cubes" },
        "trophies": { "$ref": "#/definitions/trophies" },
        "showcase": {
          "type": "object",
          "additionalProperties": false,
          "description": "Tuning for the auto-generated CORTEX:SHOWCASE block.",
          "properties": {
            "base_url": { "type": "string", "default": "", "description": "Override the URL prefix for variant image src. Empty = default <user>/<user>/main/assets path." }
          }
        }
      }
    },

    "galaxy": {
      "type": "object",
      "additionalProperties": false,
      "description": "Skill Galaxy / Constellation — stars + connections drifting in space.",
      "properties": {
        "enabled":       { "type": "boolean", "default": false },
        "title":         { "type": "string", "default": "" },
        "stars":         { "type": "array", "items": { "$ref": "#/definitions/star" }, "default": [] },
        "connections":   { "type": "array", "items": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }, "default": [] },
        "background":    { "type": "string", "enum": ["deep-space", "nebula", "void"], "default": "deep-space" },
        "twinkle_speed": { "type": "number", "default": 1.0 },
        "drift_speed":   { "type": "number", "default": 1.0 },
        "height":        { "type": "integer", "minimum": 200, "maximum": 1200, "default": 540 }
      }
    },

    "star": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string" },
        "color": { "type": "string", "default": "" },
        "size":  { "type": "integer", "minimum": 2, "maximum": 12, "default": 4 }
      }
    },

    "synthwave": {
      "type": "object",
      "additionalProperties": false,
      "description": "Synthwave Horizon hero banner — receding grid, sun, mountains.",
      "properties": {
        "enabled":        { "type": "boolean", "default": false },
        "title":          { "type": "string", "default": "" },
        "subtitle":       { "type": "string", "default": "" },
        "height":         { "type": "integer", "minimum": 120, "maximum": 600, "default": 320 },
        "palette":        { "type": "string", "enum": ["sunset", "neon", "miami", "outrun"], "default": "outrun" },
        "show_grid":      { "type": "boolean", "default": true },
        "show_sun":       { "type": "boolean", "default": true },
        "show_mountains": { "type": "boolean", "default": true }
      }
    },

    "radar": {
      "type": "object",
      "additionalProperties": false,
      "description": "Skill Radar / Polar Chart — translucent polygon over polar grid.",
      "properties": {
        "enabled":   { "type": "boolean", "default": false },
        "title":     { "type": "string", "default": "" },
        "axes":      { "type": "array", "items": { "$ref": "#/definitions/radarAxis" }, "default": [] },
        "max_value": { "type": "number", "default": 100 },
        "color":     { "type": "string", "default": "" },
        "breathe":   { "type": "boolean", "default": true },
        "height":    { "type": "integer", "minimum": 240, "maximum": 1000, "default": 480 }
      }
    },

    "radarAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number", "default": 50 }
      }
    },

    "roadmap": {
      "type": "object",
      "additionalProperties": false,
      "description": "Code Roadmap — metro/subway-style multi-line career map.",
      "properties": {
        "enabled":     { "type": "boolean", "default": false },
        "title":       { "type": "string", "default": "" },
        "lines":       { "type": "array", "items": { "$ref": "#/definitions/metroLine" }, "default": [] },
        "show_legend": { "type": "boolean", "default": true },
        "height":      { "type": "integer", "minimum": 200, "maximum": 800, "default": 360 }
      }
    },

    "metroLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name":     { "type": "string" },
        "color":    { "type": "string", "default": "" },
        "stations": { "type": "array", "items": { "$ref": "#/definitions/metroStation" }, "default": [] }
      }
    },

    "metroStation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label":      { "type": "string" },
        "year":       { "type": "integer", "default": 0 },
        "is_current": { "type": "boolean", "default": false }
      }
    },

    "heatmap": {
      "type": "object",
      "additionalProperties": false,
      "description": "Activity Heatmap — 7x52 contribution grid with neon glow.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "weeks":   { "type": "integer", "minimum": 12, "maximum": 104, "default": 52 },
        "data":    { "type": "array", "items": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 4 } }, "default": [] },
        "palette": { "type": "string", "enum": ["neon-green", "neon-cyan", "neon-rainbow", "rose"], "default": "neon-green" },
        "glow":    { "type": "boolean", "default": true },
        "height":  { "type": "integer", "minimum": 140, "maximum": 400, "default": 200 }
      }
    },

    "cubes": {
      "type": "object",
      "additionalProperties": false,
      "description": "3D Stat Cubes — isometric blocks orbiting slowly.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "cubes":   { "type": "array", "items": { "$ref": "#/definitions/statCube" }, "default": [] },
        "orbit":   { "type": "boolean", "default": true },
        "height":  { "type": "integer", "minimum": 200, "maximum": 600, "default": 280 }
      }
    },

    "statCube": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "color": { "type": "string", "default": "" }
      }
    },

    "trophies": {
      "type": "object",
      "additionalProperties": false,
      "description": "Achievement Wall / Trophy Cabinet — beveled cabinet with trophies.",
      "properties": {
        "enabled":  { "type": "boolean", "default": false },
        "title":    { "type": "string", "default": "" },
        "trophies": { "type": "array", "items": { "$ref": "#/definitions/trophy" }, "default": [] },
        "columns":  { "type": "integer", "minimum": 1, "maximum": 8, "default": 4 },
        "height":   { "type": "integer", "minimum": 200, "maximum": 800, "default": 360 }
      }
    },

    "trophy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string" },
        "date":  { "type": "string", "default": "" },
        "glyph": { "type": "string", "default": "" },
        "color": { "type": "string", "default": "" }
      }
    },

    "badges": {
      "type": "object",
      "additionalProperties": false,
      "description": "Compact skill / tech / achievement badges. 4 shapes x 3 layouts x 4 animations.",
      "properties": {
        "enabled":   { "type": "boolean", "default": false },
        "shape":     { "type": "string", "enum": ["pill", "hex", "shield", "circle"], "default": "pill" },
        "layout":    { "type": "string", "enum": ["row", "grid", "marquee"], "default": "row" },
        "columns":   { "type": "integer", "minimum": 1, "maximum": 16, "default": 6 },
        "animation": { "type": "string", "enum": ["stagger", "shimmer", "pulse", "static"], "default": "stagger" },
        "items":     { "type": "array", "items": { "$ref": "#/definitions/badgeItem" }, "maxItems": 30, "default": [] }
      }
    },

    "badgeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label":    { "type": "string", "description": "Visible badge label (e.g. 'Python', 'AWS Pro')." },
        "icon":     { "type": "string", "default": "", "description": "Built-in icon slug (e.g. python, rust, aws). Resolves to monogram + brand color." },
        "icon_svg": { "type": "string", "default": "", "description": "Raw SVG path d-string normalized to a 24-unit canvas. Overrides built-in monogram." },
        "color":    { "type": "string", "default": "", "description": "Override badge background color (hex). Empty = use brand color from icon slug or jewel-tone violet fallback." },
        "value":    { "type": "string", "default": "", "description": "Optional sublabel (e.g. 'Senior', '85%', 'Certified'). Shown on pill/hex/shield, hidden on circle." },
        "href":     { "type": "string", "default": "", "description": "Optional URL — wraps the badge in an anchor." }
      }
    },

    "banner": {
      "type": "object",
      "additionalProperties": false,
      "description": "Animated header/footer banner — capsule-render replacement.",
      "properties": {
        "enabled":   { "type": "boolean", "default": true },
        "shape":     { "type": "string", "enum": ["wave", "slice", "rect"], "default": "wave" },
        "title":     { "type": "string", "default": "" },
        "subtitle":  { "type": "string", "default": "" },
        "height":    { "type": "integer", "minimum": 60, "maximum": 600, "default": 220 },
        "colors":    { "type": "array", "items": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }, "default": [] },
        "animation": { "type": "string", "enum": ["drift", "pulse", "static"], "default": "drift" }
      }
    },

    "focusTile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project"],
      "properties": {
        "project":     { "type": "string" },
        "status":      { "type": "string", "enum": ["ACTIVE", "SHIPPING", "EXPLORING", "MAINTAINING", "BUILDING"], "default": "ACTIVE" },
        "accent":      { "type": "string", "enum": ["red", "orange", "green", "gold", "cyan", "purple"], "default": "red" },
        "emoji":       { "type": "string", "default": "", "description": "Optional emoji shown on the tile" },
        "description": { "type": "string", "default": "", "description": "Word-wrapped to <=3 lines" },
        "tech":        { "type": "array", "items": { "type": "string" }, "maxItems": 4, "default": [] }
      }
    },

    "autoUpdate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schedule": { "type": "string", "default": "0 6 * * *", "description": "Cron schedule (UTC)" },
        "markers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "activity":         { "type": "boolean", "default": true },
            "latest_releases":  { "type": "boolean", "default": true },
            "quote_of_the_day": { "type": "boolean", "default": true },
            "gitgraph":         { "type": "boolean", "default": true },
            "highlights_stats": { "type": "boolean", "default": true },
            "skyline_grid":     { "type": "boolean", "default": true },
            "city_grid":        { "type": "boolean", "default": true },
            "stl_links":        { "type": "boolean", "default": true },
            "gitcity_links":    { "type": "boolean", "default": true },
            "showcase":         { "type": "boolean", "default": true, "description": "Auto-update CORTEX:SHOWCASE block in README with all-widgets gallery + config snippets." },
            "pagespeed": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean", "default": false },
                "url":     { "type": "string",  "format": "uri" }
              }
            },
            "wakatime": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    },

    "contributions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "snake":      { "type": "boolean", "default": true },
        "skylines":   { "type": "object", "additionalProperties": false, "properties": { "years": { "type": "array", "items": { "type": "integer" } }, "stl": { "type": "boolean", "default": true } } },
        "cities":     { "type": "object", "additionalProperties": false, "properties": { "years": { "type": "array", "items": { "type": "integer" } } } },
        "profile_3d": { "type": "boolean", "default": true }
      }
    },

    "proFeatures": {
      "type": "object",
      "additionalProperties": false,
      "description": "Pro tier — gated behind subscription in v2+",
      "properties": {
        "ai_portrait":       { "type": "boolean", "default": false },
        "skill_dna_strand":  { "type": "boolean", "default": false },
        "project_cards":     { "type": "boolean", "default": false },
        "digital_twin_chat": { "type": "boolean", "default": false },
        "constellation":     { "type": "boolean", "default": false },
        "sound_reactive":    { "type": "boolean", "default": false },
        "custom_domain":     { "type": "string" },
        "analytics":         { "type": "boolean", "default": false }
      }
    }
  }
}
